<%= turbo_frame_tag "email-preview" do %>
  <div class="border-2 border-dashed border-red-200 rounded-lg p-8 text-center bg-red-50">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-red-400 mb-3">
      <circle cx="12" cy="12" r="10"></circle>
      <line x1="15" y1="9" x2="9" y2="15"></line>
      <line x1="9" y1="9" x2="15" y2="15"></line>
    </svg>
    <p class="text-red-600 text-sm font-medium mb-1">Something went wrong</p>
    <p class="text-red-500 text-xs"><%= message %></p>
  </div>
<% end %>
